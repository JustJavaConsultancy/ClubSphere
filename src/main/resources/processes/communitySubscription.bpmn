<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xmlns:flowable="http://flowable.org/bpmn"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI"
             typeLanguage="http://www.w3.org/2001/XMLSchema"
             expressionLanguage="http://www.w3.org/1999/XPath"
             targetNamespace="http://flowable.org/test">

  <process id="communitySubscription" name="Community Subscription" isExecutable="true">

    <!-- 1. Start -->
    <startEvent id="start" name="Subscription Requested"/>

    <!-- 2. Initiate payment transaction -->
    <serviceTask id="initiatePayment" name="Initiate Payment"
                 flowable:delegateExpression="${initiatePaymentDelegate}"/>

    <!-- 3. Activate subscription immediately (simulated — no real payment gateway wait) -->
    <serviceTask id="activateSubscription" name="Activate Subscription"
                 flowable:delegateExpression="${activateSubscriptionDelegate}"/>

    <!-- 4. Monthly billing cycle — wait 30 days then charge again -->
    <intermediateCatchEvent id="billingTimer" name="Wait for Next Billing">
      <timerEventDefinition>
        <timeDuration>P30D</timeDuration>
      </timerEventDefinition>
    </intermediateCatchEvent>

    <!-- 5. Charge the recurring subscription -->
    <serviceTask id="chargeSubscription" name="Charge Subscription"
                 flowable:delegateExpression="${chargeSubscriptionDelegate}"/>

    <!-- 6. Update the next billing date -->
    <serviceTask id="updateBilling" name="Update Billing Date"
                 flowable:delegateExpression="${updateSubscriptionBillingDelegate}"/>

    <!-- 7. End -->
    <endEvent id="end" name="Cycle Complete"/>

    <!-- Flow -->
    <sequenceFlow id="flow1" sourceRef="start" targetRef="initiatePayment"/>
    <sequenceFlow id="flow2" sourceRef="initiatePayment" targetRef="activateSubscription"/>
    <sequenceFlow id="flow3" sourceRef="activateSubscription" targetRef="billingTimer"/>
    <sequenceFlow id="flow4" sourceRef="billingTimer" targetRef="chargeSubscription"/>
    <sequenceFlow id="flow5" sourceRef="chargeSubscription" targetRef="updateBilling"/>
    <sequenceFlow id="flow6" sourceRef="updateBilling" targetRef="end"/>

  </process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_communitySubscription">
    <bpmndi:BPMNPlane bpmnElement="communitySubscription" id="BPMNPlane_communitySubscription">
      <bpmndi:BPMNShape bpmnElement="start" id="BPMNShape_start">
        <omgdc:Bounds height="30.0" width="30.0" x="100.0" y="163.0"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="initiatePayment" id="BPMNShape_initiatePayment">
        <omgdc:Bounds height="80.0" width="100.0" x="200.0" y="138.0"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="activateSubscription" id="BPMNShape_activateSubscription">
        <omgdc:Bounds height="80.0" width="100.0" x="370.0" y="138.0"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="billingTimer" id="BPMNShape_billingTimer">
        <omgdc:Bounds height="30.0" width="30.0" x="540.0" y="163.0"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="chargeSubscription" id="BPMNShape_chargeSubscription">
        <omgdc:Bounds height="80.0" width="100.0" x="640.0" y="138.0"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="updateBilling" id="BPMNShape_updateBilling">
        <omgdc:Bounds height="80.0" width="100.0" x="810.0" y="138.0"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="end" id="BPMNShape_end">
        <omgdc:Bounds height="28.0" width="28.0" x="980.0" y="164.0"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge bpmnElement="flow1" id="BPMNEdge_flow1">
        <omgdi:waypoint x="130.0" y="178.0"/>
        <omgdi:waypoint x="200.0" y="178.0"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="flow2" id="BPMNEdge_flow2">
        <omgdi:waypoint x="300.0" y="178.0"/>
        <omgdi:waypoint x="370.0" y="178.0"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="flow3" id="BPMNEdge_flow3">
        <omgdi:waypoint x="470.0" y="178.0"/>
        <omgdi:waypoint x="540.0" y="178.0"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="flow4" id="BPMNEdge_flow4">
        <omgdi:waypoint x="570.0" y="178.0"/>
        <omgdi:waypoint x="640.0" y="178.0"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="flow5" id="BPMNEdge_flow5">
        <omgdi:waypoint x="740.0" y="178.0"/>
        <omgdi:waypoint x="810.0" y="178.0"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="flow6" id="BPMNEdge_flow6">
        <omgdi:waypoint x="910.0" y="178.0"/>
        <omgdi:waypoint x="980.0" y="178.0"/>
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</definitions>

