<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:flowable="http://flowable.org/bpmn" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC" xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI" xmlns:design="http://flowable.org/design" typeLanguage="http://www.w3.org/2001/XMLSchema" expressionLanguage="http://www.w3.org/1999/XPath" targetNamespace="http://flowable.org/test" exporter="Flowable Design" exporterVersion="2025.1.03" design:palette="flowable-work-process-palette">
  <process id="invoicing" name="invoicing" isExecutable="true" flowable:candidateStarterGroups="flowableUser">
    <documentation>Form Submission URL: @{http://localhost:9000/processes/start}

Submit button caption : Start
businessName:
type: text
label: Business Name
placeholder: Acme Corporation
required: true
labelCss: block text-sm font-medium text-slate-300 mb-2
inputCss: form-input w-full px-4 py-3 rounded-lg border pr-12

clientName:
type: text
label: Client Name
placeholder: Jane Doe
required: true
labelCss: block text-sm font-medium text-slate-300 mb-2
inputCss: form-input w-full px-4 py-3 rounded-lg border pr-12

email:
type: text
label: Email
placeholder: contact@acme.com
required: true
labelCss: block text-sm font-medium text-slate-300 mb-2
inputCss: form-input w-full px-4 py-3 rounded-lg border pr-12

address:
type: text
label: Address
placeholder: Ikeja, Lagos
required: true
labelCss: block text-sm font-medium text-slate-300 mb-2
inputCss: form-input w-full px-4 py-3 rounded-lg border pr-12

phoneNumber:
type: text
label: Phone (Optional)
placeholder: +234 9055529102
required: true
labelCss: block text-sm font-medium text-slate-300 mb-2
inputCss: form-input w-full px-4 py-3 rounded-lg border pr-12

amount:
type: number
label: Amount
placeholder: 0.00
required: true
labelCss: block text-sm font-medium text-slate-300 mb-2
inputCss: form-input w-full px-4 py-3 rounded-lg border pr-12

dueDate:
type: date
label: Phone (Optional)
placeholder: dd/mm/yyyy
required: true
labelCss: block text-sm font-medium text-slate-300 mb-2
inputCss: form-input w-full px-4 py-3 rounded-lg border pr-12

description:
type: textarea
label: Description (Optional)
placeholder: service description
required: true
labelCss: block text-sm font-medium text-slate-300 mb-2
inputCss: form-input w-full px-4 py-3 rounded-lg border pr-12</documentation>
    <extensionElements>
      <design:stencilid><![CDATA[BPMNDiagram]]></design:stencilid>
      <design:creationdate><![CDATA[2025-08-07T13:16:40.052Z]]></design:creationdate>
      <design:modificationdate><![CDATA[2025-12-07T11:27:15.375Z]]></design:modificationdate>
    </extensionElements>
    <userTask id="FormTask_SeniorReview" name="Review" flowable:assignee="manager" flowable:formFieldValidation="false">
      <extensionElements>
        <flowable:task-candidates-type><![CDATA[all]]></flowable:task-candidates-type>
        <design:stencilid><![CDATA[FormTask]]></design:stencilid>
        <design:stencilsuperid><![CDATA[Task]]></design:stencilsuperid>
      </extensionElements>
    </userTask>
    <scriptTask id="ServiceTask_5" name="Invoice Delivery" scriptFormat="javascript" flowable:autoStoreVariables="false">
      <extensionElements>
        <design:stencilid><![CDATA[ScriptTask]]></design:stencilid>
        <design:stencilsuperid><![CDATA[Task]]></design:stencilsuperid>
      </extensionElements>
      <script><![CDATA[var processInstanceId = execution.getProcessInstanceId();
var baseUrl = execution.getVariable("baseUrl");
var invoiceLink = baseUrl+"/invoice/pay/" +processInstanceId;
print(invoiceLink);
execution.setVariable("invoiceLink", invoiceLink);]]></script>
    </scriptTask>
    <serviceTask id="ServiceTask_7" name="Email Task" flowable:expression="${emailService.sendMail(execution)}">
      <extensionElements>
        <design:stencilid><![CDATA[ServiceTask]]></design:stencilid>
        <design:stencilsuperid><![CDATA[Task]]></design:stencilsuperid>
      </extensionElements>
    </serviceTask>
    <userTask id="FormTask_ClientPayment" name="Client Payment" flowable:formFieldValidation="false">
      <extensionElements>
        <flowable:task-candidates-type><![CDATA[all]]></flowable:task-candidates-type>
        <design:stencilid><![CDATA[FormTask]]></design:stencilid>
        <design:stencilsuperid><![CDATA[Task]]></design:stencilsuperid>
      </extensionElements>
    </userTask>
    <scriptTask id="ServiceTask_10" name="Invoice Updated" scriptFormat="javascript" flowable:autoStoreVariables="false">
      <extensionElements>
        <design:stencilid><![CDATA[ScriptTask]]></design:stencilid>
        <design:stencilsuperid><![CDATA[Task]]></design:stencilsuperid>
      </extensionElements>
      <script><![CDATA[var payStackStatus = execution.getVariable("payStackStatus");

if(payStackStatus == "success"){
  execution.setVariable("status", "paid");
} else{
  execution.setVariable("status", "failed");
}
print(status);]]></script>
    </scriptTask>
    <userTask id="FormTask_EditInvoice" name="Edit Invoice" flowable:formFieldValidation="false">
      <extensionElements>
        <flowable:task-candidates-type><![CDATA[all]]></flowable:task-candidates-type>
        <design:stencilid><![CDATA[FormTask]]></design:stencilid>
        <design:stencilsuperid><![CDATA[Task]]></design:stencilsuperid>
      </extensionElements>
    </userTask>
    <serviceTask id="ServiceTask_14" name="Reminder Mail Task" flowable:expression="${emailService.sendReminder(execution)}">
      <extensionElements>
        <design:stencilid><![CDATA[ServiceTask]]></design:stencilid>
        <design:stencilsuperid><![CDATA[Task]]></design:stencilsuperid>
      </extensionElements>
    </serviceTask>
    <serviceTask id="ServiceTask_29" name="Approval Mail Task" flowable:expression="${emailService.sendApproval(execution)}">
      <extensionElements>
        <design:stencilid><![CDATA[ServiceTask]]></design:stencilid>
        <design:stencilsuperid><![CDATA[Task]]></design:stencilsuperid>
      </extensionElements>
    </serviceTask>
    <exclusiveGateway id="Exclusive_Databased_Gateway_13">
      <extensionElements>
        <design:stencilid><![CDATA[Exclusive_Databased_Gateway]]></design:stencilid>
      </extensionElements>
    </exclusiveGateway>
    <parallelGateway id="ParallelGateway_25">
      <extensionElements>
        <design:stencilid><![CDATA[ParallelGateway]]></design:stencilid>
      </extensionElements>
    </parallelGateway>
    <parallelGateway id="ParallelGateway_27">
      <extensionElements>
        <design:stencilid><![CDATA[ParallelGateway]]></design:stencilid>
      </extensionElements>
    </parallelGateway>
    <startEvent id="startnoneevent1" flowable:initiator="initiator" flowable:formFieldValidation="false">
      <extensionElements>
        <flowable:work-form-field-validation><![CDATA[false]]></flowable:work-form-field-validation>
        <design:stencilid><![CDATA[StartNoneEvent]]></design:stencilid>
      </extensionElements>
    </startEvent>
    <endEvent id="EndNoneEvent_13">
